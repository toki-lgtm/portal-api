# Supabase
SUPABASE_URL=your_supabase_url
# server.js は SERVICE_ROLE_KEY を優先使用（無ければ ANON_KEY）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# 認証（必須）: JWT署名鍵。十分に長いランダム文字列を設定すること
JWT_SECRET=change_me_to_a_long_random_secret
# ログインを許可する会社ドメイン（既定: nakahara131.co.jp）
ALLOWED_EMAIL_DOMAIN=nakahara131.co.jp

# CORS: 許可オリジンをカンマ区切りで指定（未設定なら全許可=本番非推奨）
# 例: https://portal-xxxx.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

# 既存アプリ URL
SAFETY_PATROL_URL=https://safety-patrol-app.vercel.app

# Server
PORT=3000
NODE_ENV=development

# ===== メール送信（SMTP / 自社メール bizmw, nakahara131.co.jp） =====
# 点検報告PDFを作業所長へ送信する機能で使用。
# 送信専用アカウント system_noreply@nakahara131.co.jp（表示名「中原建設社内システム」）を利用。
# ※ SMTP_PASS（パスワード）は本番では必ず Render の環境変数に設定し、ここには書かないこと。
SMTP_HOST=nakahara131.co.jp
SMTP_PORT=587
SMTP_USER=system_noreply@nakahara131.co.jp
SMTP_PASS=your_mail_account_password
MAIL_FROM=system_noreply@nakahara131.co.jp
MAIL_FROM_NAME=中原建設社内システム
